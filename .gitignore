# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.env
.env.*

# Claude Code local (personal, machine-specific) settings
.claude/settings.local.json

# Deploy-time quarantine holding area (see deploy_quarantine.py) — must
# never contain anything except transiently, between quarantine and restore
.deploy_quarantine_holding/

# Wrangler
.wrangler/
html/.wrangler/

# Legacy VPS/nginx mirror — its own nested git repo (embedded/submodule),
# not the live site (Cloudflare Pages serves repo root). `git add -A`
# without this stages it as a gitlink and breaks Pages builds — this
# happened once already, fixed in ba906b0.
html/

# Chrome profile data (large, binary)
social_agent/data/quora_chrome_profile/

# SQLite DB (runtime state, not source)
social_agent/data/posts.db
social_agent/data/twitter_token.json

# Screenshots / audit images (generated)
